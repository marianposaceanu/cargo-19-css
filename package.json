{
  "name": "cargo19-css",
  "version": "1.3.1",
  "description": "Independent retro-future CSS framework combining the original visual system with 59 generated semiotic icons and self-hosted documentation.",
  "homepage": "https://marianposaceanu.github.io/cargo-19-css/",
  "author": {
    "name": "Marian Posaceanu",
    "url": "https://marianposaceanu.com/"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/marianposaceanu/cargo-19-css.git"
  },
  "style": "dist/cargo19.css",
  "main": "dist/cargo19.js",
  "files": [
    "dist",
    "src",
    "icons",
    "DIST-SHA256.txt",
    "COMPONENTS.md",
    "FONT-SOURCES.md",
    "NOTICE.md",
    "CHANGELOG.md",
    "manifest.json"
  ],
  "scripts": {
    "build": "ruby tools/release.rb",
    "build:css": "ruby tools/build.rb",
    "build:icons": "ruby tools/build_icons.rb",
    "build:docs": "ruby tools/build_docs.rb",
    "validate": "ruby tools/validate.rb"
  },
  "keywords": [
    "css",
    "framework",
    "design-system",
    "semiotic",
    "icons",
    "operational-ui",
    "sci-fi"
  ],
  "license": "MIT",
  "sideEffects": [
    "*.css"
  ]
}
